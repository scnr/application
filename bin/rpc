#!/usr/bin/env ruby
require_relative '../lib/scnr/application'

agent = SCNR::Application.spawn( :agent, daemonize: true )

instance = SCNR::Application.connect( agent.spawn )

instance.run(
    multi: {
      instances: 5
    },
    url:    'http://testfire.net/',
    audit:  {
        elements: [:links, :forms, :cookies]
    },
    checks: ['*']
)

while instance.busy?
    progress = instance.scan.progress(
      as_hash: true,
      with: [:issues, :sitemap, :errors]
    )

    # if progress['multi']['auditors'].any?
    #     instance.suspend!
    # end
    sleep 1
end

ap report = instance.generate_report.data
ap report.finish_datetime - report.start_datetime

instance.shutdown
