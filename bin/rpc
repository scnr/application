#!/usr/bin/env ruby
require_relative '../lib/scnr/application'

agent = SCNR::Application.spawn( :agent )

instance = SCNR::Application.connect( agent.spawn )

instance.run(
    # multi: {
    #   processes: 5
    # },
    url:    'http://testhtml5.vulnweb.com/',
    audit:  {
        elements: [:links, :forms, :cookies]
    },
    checks: ['*']
)

t = Time.now

while instance.busy?
    # ap instance.scan.progress(
    #   as_hash: true,
    #   with: [:issues, :sitemap, :errors]
    # )
    sleep 1
end

total = Time.now - t

report = instance.generate_report.data

ap report.issues.size
p report.issues.map(&:name).map(&:to_s)

ap total

instance.shutdown
