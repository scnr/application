#!/usr/bin/env ruby
require_relative '../lib/scnr/application'

agent = SCNR::Application.spawn( :agent )

instance = SCNR::Application.connect( agent.spawn )

instance.run(
    multi: {
      processes: 5
    },
    url:    'http://testhtml5.vulnweb.com/',
    audit:  {
        elements: [:links, :forms, :cookies]
    },
    checks: ['*']
)

while instance.busy?
    # ap instance.scan.progress(
    #   as_hash: true,
    #   with: [:issues, :sitemap, :errors]
    # )
    sleep 1
end

ap report = instance.generate_report.data
ap report.finish_datetime - report.start_datetime

instance.shutdown
