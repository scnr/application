#!/usr/bin/env ruby
require_relative '../lib/scnr/application'

agent = SCNR::Application.spawn( :agent )

instance = SCNR::Application.connect( agent.spawn )

instance.run(
    # multi: {
    #   processes: 5
    # },
    url:    'http://testhtml5.vulnweb.com/',
    audit:  {
        elements: [:links, :forms, :cookies]
    },
    checks: ['*']
)

t = Time.now

while instance.scan.progress['status'] != 'done'
    # ap instance.scan.progress(
    #   as_hash: true,
    #   with: [:issues, :sitemap, :errors]
    # )
    sleep 1
end

total = Time.now - t

ap instance.generate_report.data.issues.size
p instance.generate_report.data.issues.map(&:name).map(&:to_s)

ap total

# 23
# 191

# 15
# 384

# 20
# 154

# 16
# 210

instance.shutdown
